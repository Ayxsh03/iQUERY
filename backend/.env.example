# ─────────────────────────────────────────────────────────────────────
# iQuery — Environment Variables
# Copy this to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────

# ── LLM Configuration ────────────────────────────────────────────────
# Primary LLM provider: "groq" or "ollama"
LLM_PROVIDER=groq

# Groq API key — free tier at https://console.groq.com (takes 30 sec)
GROQ_API_KEY=your_groq_api_key_here

# Groq model (free tier options: llama3-8b-8192, mixtral-8x7b-32768)
GROQ_MODEL=llama3-8b-8192

# Ollama settings (only needed if LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# ── Embedding ────────────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Vector Store ─────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=intraquery_docs

# ── Chunking ─────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ── Retrieval ────────────────────────────────────────────────────────
TOP_K_RESULTS=5

# ── Database ─────────────────────────────────────────────────────────
# Path to the SQLite file (relative to where uvicorn is started)
DB_PATH=./iquery.db

# ── App ──────────────────────────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# ── CORS ─────────────────────────────────────────────────────────────
# Production frontend URL — set this on Render/Railway to allow cross-origin chat
# Example: https://iquery-frontend.onrender.com
FRONTEND_URL=
